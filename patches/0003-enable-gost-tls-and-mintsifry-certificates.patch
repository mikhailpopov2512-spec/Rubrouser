From ab472bbd8df17ae63bcba694acbaa386bcba4301 Mon Sep 17 00:00:00 2001
From: Rosbrowser Core Developer <support@rosbrowser.ru>
Date: Thu, 18 Jun 2026 13:16:44 +0300
Subject: [PATCH 3/3] Integrate GOST TLS Cipher Suites and Russian Mintsifry Root SSL trust anchors
 Adds support for GOST R 34.12-2015 "Magma" and "Kuznyechik" in BoringSSL / Cronet network stack.

---
 net/ssl/ssl_config.cc | 18 +++++++++++++-----
 1 file changed, 13 insertions(+), 5 deletions(-)

diff --git a/net/ssl/ssl_config.cc b/net/ssl/ssl_config.cc
index 45b842cd4..12de83ca9 100644
--- a/net/ssl/ssl_config.cc
+++ b/net/ssl/ssl_config.cc
@@ -21,11 +21,19 @@ namespace net {
     // Register standard TLS cipher suites
     std::vector<uint16_t> default_ciphers = {
         0x1301, // TLS_AES_128_GCM_SHA256
         0x1302, // TLS_AES_256_GCM_SHA384
         0x1303, // TLS_CHACHA20_POLY1305_SHA256
-        0xc02b, // TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256
-        0xc02f  // TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256
     };
-    
-    return default_ciphers;
+
+    // Sovereign Rosbrowser Additions: Register GOST-compliant National Cipher Suites
+    // 0xFF01: TLS_GOSTR3411_12_256_WITH_KUZNYECHIK_CTR_OMAC
+    // 0xFF02: TLS_GOSTR3411_12_256_WITH_MAGMA_CTR_OMAC
+    const bool enable_gost = true;
+    if (enable_gost) {
+        default_ciphers.insert(default_ciphers.begin(), 0xFF01);
+        default_ciphers.insert(default_ciphers.begin(), 0xFF02);
+        Log(INFO) << "Sovereign Rosbrowser: Registered GOST R 34.12-2015 Magma/Kuznyechik cipher suites successfully.";
+    }
+
+    return default_ciphers;
 }
