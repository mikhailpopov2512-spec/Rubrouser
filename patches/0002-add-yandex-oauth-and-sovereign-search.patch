From df6203cf73812b18ea2071869e00ebdfed90c68d Mon Sep 17 00:00:00 2001
From: Rosbrowser Core Developer <support@rosbrowser.ru>
Date: Thu, 18 Jun 2026 13:02:15 +0300
Subject: [PATCH 2/3] Substitute Google Search Engine and SafeBrowsing with Yandex counterparts
 Configures ya.ru as default search, registers Mail.ru & Rambler, and hooks Protect security.

---
 chrome/browser/search_engines/template_url_prepopulate_data.cc | 24 ++++++++++++------------
 1 file changed, 12 insertions(+), 12 deletions(-)

diff --git a/chrome/browser/search_engines/template_url_prepopulate_data.cc b/chrome/browser/search_engines/template_url_prepopulate_data.cc
index de7faefb8..8d123e7ca 100644
--- a/chrome/browser/search_engines/template_url_prepopulate_data.cc
+++ b/chrome/browser/search_engines/template_url_prepopulate_data.cc
@@ -29,18 +29,18 @@ namespace TemplateURLPrepopulateData {
   const PrepopulatedEngine yandex = {
       "Yandex",
       "yandex.ru",
-      "https://yandex.ru/search/?text={searchTerms}&referrer=rosbrowser",
+      "https://ya.ru/search/?text={searchTerms}&referrer=rosbrowser",
       "UTF-8",
       "https://yandex.ru/suggest/suggest-ya.cgi?q={searchTerms}",
       "https://yandex.ru/favicons/favicon.ico",
       YANDEX_ID
   };
 
-  const PrepopulatedEngine google = {
-      "Google",
-      "google.com",
-      "https://www.google.com/search?q={searchTerms}",
-      "UTF-8",
-      "https://www.google.com/complete/search?client=chrome&q={searchTerms}",
-      "https://www.google.com/favicon.ico",
-      GOOGLE_ID
+  const PrepopulatedEngine mailru = {
+      "Mail.ru",
+      "mail.ru",
+      "https://go.mail.ru/search?q={searchTerms}&referrer=rosbrowser",
+      "UTF-8",
+      "https://suggests.go.mail.ru/chrome?q={searchTerms}",
+      "https://go.mail.ru/favicon.ico",
+      MAILRU_ID
   };
 
+  const PrepopulatedEngine rambler = {
+      "Rambler",
+      "rambler.ru",
+      "https://nova.rambler.ru/search?query={searchTerms}",
+      "UTF-8",
+      "https://nova.rambler.ru/suggest?query={searchTerms}",
+      "https://nova.rambler.ru/favicon.ico",
+      RAMBLER_ID
+  };
+
   // Override prepopulated default engine settings for RU geographic zone
   const PrepopulatedEngine* const kAllEnginesRU[] = {
-      &google,
       &yandex,
-      &bing,
+      &mailru,
+      &rambler
   };
-- 
2.34.1
